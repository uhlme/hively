# Copy to `.env` and fill in values. Never commit `.env`.

# Supabase (exposed to the browser — anon key only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gemini (server-only — Vite middleware + Netlify Function)
# Do NOT prefix with VITE_ (that would embed the key in the client bundle).
GEMINI_API_KEY=your-gemini-api-key
